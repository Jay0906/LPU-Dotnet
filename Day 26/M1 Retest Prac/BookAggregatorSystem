using System;
using System.Collections.Generic;
using System.Linq;

class BookManager
{
    Dictionary<string, Dictionary<string,int>> userReviews =
        new Dictionary<string, Dictionary<string,int>>();

    Dictionary<string, List<(string user,int rating)>> bookReviews =
        new Dictionary<string, List<(string,int)>>();

    public void review(string user,string book,int rating)
    {
        // WRITE CODE
        if (!userReviews.ContainsKey(user))
        {
            userReviews[user]=new Dictionary<string, int>();
        }
        if (!bookReviews.ContainsKey(book))
        {
            bookReviews[book]=new List<(string user, int rating)>();
        }
        if (!userReviews[user].ContainsKey(book))
        {
            userReviews[user][book]=rating;
            bookReviews[book].Add((user,rating));
        }
        else if (rating > userReviews[user][book])
        {
            userReviews[user][book]=rating;
            for(int i = 0; i < bookReviews[book].Count; i++)
            {
                if (bookReviews[book][i].user == user)
                {
                    bookReviews[book][i]=(user,rating);
                }
            }
        }
    }

    public void remove(string user,string book)
    {
        // WRITE CODE
        if(userReviews.ContainsKey(user) || userReviews[user].ContainsKey(book))
        {
            userReviews[user].Remove(book);
            if (userReviews[user].Count == 0)
            {
                userReviews.Remove(user);
            }
        }
        if (bookReviews.ContainsKey(book))
        {
            bookReviews[book].RemoveAll(x=>x.user==user);
        }
    }

    public void top(string book)
    {
        // WRITE CODE
        if(!bookReviews.ContainsKey(book) || bookReviews[book].Count == 0)
        {
            Console.WriteLine("No Reviews");
            return;
        }
        var top=bookReviews[book].Max(x=>x.rating);
        foreach(var item in bookReviews[book])
        {
            if (item.rating == top)
            {
                Console.WriteLine($"{item.user} - {item.rating}");
            }
        }
    }

    public void avg(string book)
    {
        // WRITE CODE
        if(!bookReviews.ContainsKey(book) || bookReviews[book].Count == 0)
        {
            Console.WriteLine("No Ratings");
            return;
        }
        var avg=bookReviews[book].Average(x=>x.rating);
        Console.WriteLine($"{book} - {avg.ToString("F2")}");
    }

    public void process(List<string> commands)
    {
        foreach(var cmd in commands)
        {
            string[] p = cmd.Split();

            if(p[0]=="REVIEW")
                review(p[1],p[2],int.Parse(p[3]));

            else if(p[0]=="REMOVE")
                remove(p[1],p[2]);

            else if(p[0]=="TOP")
                top(p[1]);

            else if(p[0]=="AVG")
                avg(p[1]);
        }
    }
    class Program
    {
        static void Main()
        {
            int N = int.Parse(Console.ReadLine()!);

            List<string> commands = new List<string>();

            for(int i=0;i<N;i++)
                commands.Add(Console.ReadLine()!);

            BookManager manager = new BookManager();
            manager.process(commands);
        }
    }
}
