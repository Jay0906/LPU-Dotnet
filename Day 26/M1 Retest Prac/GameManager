using System;
using System.Collections.Generic;
using System.Linq;
using System.Runtime.Serialization;
using System.Security;

class GameManager
{
    Dictionary<string, Dictionary<string,int>> playerGames =
        new Dictionary<string, Dictionary<string,int>>();

    Dictionary<string, List<(string player,int score)>> gamePlayers =
        new Dictionary<string, List<(string,int)>>();

    public void play(string player,string game,int score)
    {
        // WRITE CODE
        if (!playerGames.ContainsKey(player))
        {
            playerGames[player]=new Dictionary<string, int>();
        }
        if (!gamePlayers.ContainsKey(game))
        {
            gamePlayers[game]=new List<(string player, int score)>();
        }
        if (!playerGames[player].ContainsKey(game))
        {
            playerGames[player][game]=score;
            gamePlayers[game].Add((player,score));
        }
        else if(score > playerGames[player][game])
        {
            playerGames[player][game]=score;

            for(int i = 0; i < gamePlayers[game].Count; i++)
            {
                if (gamePlayers[game][i].player == player)
                {
                    gamePlayers[game][i]=(player,score);
                }
            }
        }
    }

    public void remove(string player,string game)
    {
        // WRITE CODE
        if(playerGames.ContainsKey(player) || playerGames[player].ContainsKey(game))
        {
            playerGames[player].Remove(game);
            if (playerGames[player].Count == 0)
            {
                playerGames.Remove(player);
            }
        }
        if (gamePlayers.ContainsKey(game))
        {
            gamePlayers[game].RemoveAll(x=>x.player==player);
        }
    }

    public void leader(string game)
    {
        // WRITE CODE
        if(!gamePlayers.ContainsKey(game) || gamePlayers[game].Count == 0)
        {
            Console.WriteLine("NO Score");
            return;
        }
        var max=gamePlayers[game].Max(x=>x.score);
        foreach(var item in gamePlayers[game])
        {
            if (item.score == max)
            {
                Console.WriteLine($"{item.player} - {item.score}");
            }
        }
    }

    public void total(string player)
    {
        // WRITE CODE
        if (!playerGames.ContainsKey(player) || playerGames[player].Count==0)
        {
            Console.WriteLine("No Player");
            return;
        }
        var sum=playerGames[player].Values.Sum();
        Console.WriteLine($"{player} - {sum}");
    }
     public void process(List<string> commands)
    {
        foreach(var cmd in commands)
        {
            string[] p = cmd.Split();

            if(p[0]=="PLAY")
                play(p[1],p[2],int.Parse(p[3]));

            else if(p[0]=="REMOVE")
                remove(p[1],p[2]);

            else if(p[0]=="LEADER")
                leader(p[1]);

            else if(p[0]=="TOTAL")
                total(p[1]);
        }
    }
}

class Program
{
    static void Main()
    {
        int N = int.Parse(Console.ReadLine()!);

        List<string> commands = new List<string>();

        for(int i=0;i<N;i++)
            commands.Add(Console.ReadLine()!);

        GameManager manager = new GameManager();
        manager.process(commands);
    }
}
