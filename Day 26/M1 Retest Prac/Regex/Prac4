using System;
using System.Text.RegularExpressions;

namespace RegexPrac;

public class Prac4
{
    public static void Run()
    {
        System.Console.Write("Enter the text: ");
        string s=Console.ReadLine()!;
        string pattern=@"^[A-Z]{2}[0-9]{2}[A-Z]{1,2}[0-9]{4}$";
        bool flag=Regex.IsMatch(s,pattern);

        if (flag)
        {
            Console.WriteLine("ID Valid");
        }
        else
        {
            Console.WriteLine("ID Invalid");
        }
    }
}
