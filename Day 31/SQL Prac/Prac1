CREATE Database CompanyDB;
CREATE SCHEMA hr;
CREATE TABLE hr.Employees (
	EmployeeID INT PRIMARY KEY IDENTITY(101,1),
	Name VARCHAR(30) NOT NULL,
	Department VARCHAR(20) NOT NULL,
	Email VARCHAR(50) UNIQUE,
	Salary DECIMAL(10,2),
	IsActive BIT,
	CreatedAt DATETIME
	);
CREATE TABLE hr.SalaryDetails(
	SalaryId INT PRIMARY KEY IDENTITY(121,1),
	EmployeeID INT,
	HRA DECIMAL(8,2),
	DA DECIMAL(8,2),
	Deductions DECIMAL(8,2),
	NetSalary DECIMAL(10,2),
	FOREIGN KEY (EmployeeID) REFERENCES hr.Employees(EmployeeID)
	);
