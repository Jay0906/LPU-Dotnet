-- SalaryDetails Table
CREATE TABLE hr.SalaryDetails(
    SalaryId INT PRIMARY KEY IDENTITY(1,1),
    EmployeeID INT NOT NULL,
    HRA DECIMAL(8,2),
    DA DECIMAL(8,2),
    Deductions DECIMAL(8,2),
    NetSalary DECIMAL(10,2),
    FOREIGN KEY (EmployeeID) REFERENCES hr.Employees(EmployeeID)
);

