SELECT * FROM hr.Employees;

SELECT TOP 1 e.Department, SUM(s.NetSalary) AS TotalSalary
FROM hr.Employees e
JOIN hr.SalaryDetails s
ON e.EmployeeID=s.EmployeeID
GROUP BY e.Department
ORDER BY TotalSalary DESC;

SELECT e.Name,s.NetSalary
FROM hr.Employees e
JOIN hr.SalaryDetails s
ON e.EmployeeID=s.EmployeeID
WHERE s.NetSalary>(
    SELECT AVG(NetSalary) FROM hr.SalaryDetails);

SELECT e.Name,s.NetSalary,
CASE   
    WHEN s.NetSalary>70000 THEN 'High'
    WHEN s.NetSalary>50000 THEN 'Medium'
    ELSE 'LOW'
END AS SalaryLevel
FROM hr.Employees e
JOIN hr.SalaryDetails s
ON e.EmployeeID=s.EmployeeID;

SELECT e.Name, (s.HRA+s.DA-s.Deductions) AS Salary
FROM hr.Employees e
JOIN hr.SalaryDetails s
ON e.EmployeeID=s.EmployeeID;

SELECT e.Name,e.Department,s.NetSalary
FROM hr.Employees e
JOIN hr.SalaryDetails s
ON e.EmployeeID=s.EmployeeID
WHERE s.NetSalary=(
    SELECT MAX(s2.NetSalary) AS MaxSalary
    FROM hr.Employees e2
    JOIN hr.SalaryDetails s2
    ON e2.EmployeeID=s2.EmployeeID
    WHERE e2.Department=e.Department);
